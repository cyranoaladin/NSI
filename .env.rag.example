# ═══════════════════════════════════════════════════════════════════
# .env.rag.example — Modèle de connexion RAG & LLM pour le corpus NSI
# Copier vers .env.rag et remplir les valeurs réelles. chmod 600.
# ═══════════════════════════════════════════════════════════════════

# --- RAG : magasin vectoriel et recherche ---
RAG_BACKEND=chroma                              # ChromaDB v1.1.1 (confirmé)
RAG_API_BASE_URL=<URL de l'API de recherche>    # ex. https://rag-api.nexusreussite.academy/search
RAG_API_KEY=<token Bearer pour l'API>           # header Authorization: Bearer <token>
RAG_COLLECTION=rag_education                    # collection principale (2012 chunks Drive)
RAG_DISTANCE=cosine                             # métrique HNSW de la collection
RAG_VECTOR_DIM=768                              # dimension nomic-embed-text

# --- Embedding ---
# L'embedding est fait côté serveur par l'API /search (Ollama interne au Docker).
# Pour un accès direct à Ollama distant, utiliser un tunnel SSH sur un port
# libre (ex. 11435) pour éviter le conflit avec un Ollama local (11434) :
#   ssh -L 11435:127.0.0.1:11434 <user>@<host>
EMBEDDING_MODEL=nomic-embed-text                # modèle Ollama utilisé pour l'indexation
EMBEDDING_BASE_URL=<URL Ollama via tunnel>      # ex. http://127.0.0.1:11435
EMBEDDING_API_KEY=                              # vide pour Ollama sans auth

# --- Magasin vectoriel direct (ChromaDB via tunnel SSH) ---
# ssh -L 8000:127.0.0.1:8000 <user>@<host>
VECTOR_DB_URL=<URL ChromaDB via tunnel>         # ex. http://127.0.0.1:8000
VECTOR_DB_API_KEY=                              # vide si pas d'auth Chroma

# --- LLM distante (juge de substance / oracle, via tunnel SSH) ---
# Utiliser un port libre (ex. 11435) pour le tunnel vers Ollama distant :
#   ssh -L 11435:127.0.0.1:11434 <user>@<host>
LOCAL_LLM_ENGINE=ollama                         # Ollama v0.3.13 (confirmé)
LOCAL_LLM_BASE_URL=<URL Ollama /v1 via tunnel>  # ex. http://127.0.0.1:11435/v1
LOCAL_LLM_MODEL=qwen2.5:7b                     # modèle retenu (raisonnement + JSON français)
LOCAL_LLM_API_KEY=                              # vide pour Ollama sans auth

# --- Accès serveur (référence) ---
RAG_SSH_HOST=88.99.254.59
RAG_SSH_USER=<utilisateur SSH>
# Authentification SSH par clé : ne jamais stocker de mot de passe ici.
# Tunnel combiné (port 11435 pour éviter conflit Ollama local) :
#   ssh -L 11435:127.0.0.1:11434 -L 8000:127.0.0.1:8000 <user>@<host>

# --- État actuel du RAG (documenté, pas une config) ---
# rag_education : 4385 chunks Drive (sujets bac, documents divers)
# nsi_corpus    : 4182 chunks du corpus nsi-enseignement (374 fichiers .md)
# Voir SKILLS.md §17 pour la doc complète.
