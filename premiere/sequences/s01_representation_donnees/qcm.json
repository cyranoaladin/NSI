      "id": "P1Q8",
      "question": "Après notes = [12, 15, 9], puis notes[1] = 14, que produit [x * 2 for x in notes] ?",
      "propositions": [
        "[24, 28, 18]",
        "[12, 14, 9]",
        "[24, 30, 18]"
      ],
      "bonne_reponse": "[24, 28, 18]",
      "difficulte": "standard",
      "capacite_officielle": "P-DATA-CONSTR-02A",
      "erreur_ciblee": "Oublier qu'une liste est modifiable avant la compréhension.",
      "explications": {
        "[24, 28, 18]": "Réponse attendue : la valeur d'indice 1 a été modifiée avant de doubler chaque élément.",
        "[12, 14, 9]": "C'est la liste modifiée, mais la compréhension n'a pas encore été appliquée.",
        "[24, 30, 18]": "La valeur 15 a été doublée comme si la modification notes[1] = 14 n'avait pas eu lieu."
      }
