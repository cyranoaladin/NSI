  "questions": [
    {
      "id": "P1Q1",
      "question": "Que vaut 1010 en base 2 ?",
      "propositions": [
        "10",
        "1010",
        "8"
      ],
      "bonne_reponse": "10",
      "difficulte": "socle",
      "capacite_officielle": "P-DATA-BASE-01",
      "erreur_ciblee": "Lire une écriture binaire comme une écriture décimale.",
      "explications": {
        "10": "Réponse attendue.",
        "1010": "C'est la lecture en base 10, pas en base 2.",
        "8": "Le bit de poids 2 est oublié."
      }
    },
    {
      "id": "P1Q2",
      "question": "Quel est l'intervalle des entiers relatifs sur 8 bits en complément à deux ?",
      "propositions": [
        "-128 à 127",
        "0 à 255",
        "-127 à 128"
      ],
      "bonne_reponse": "-128 à 127",
      "difficulte": "standard",
      "capacite_officielle": "P-DATA-BASE-02B",
      "erreur_ciblee": "Confondre entier signé et non signé.",
      "explications": {
        "-128 à 127": "Réponse attendue.",
        "0 à 255": "C'est l'intervalle sans signe.",
        "-127 à 128": "La borne négative est mal calculée."
      }
    },
    {
      "id": "P1Q3",
      "question": "Que vaut 11111111 en complément à deux sur 8 bits ?",
