      "bonne_reponse": "-1",
      "difficulte": "standard",
      "capacite_officielle": "P-DATA-BASE-02B",
      "erreur_ciblee": "Oublier la convention de signe.",
      "explications": {
        "-1": "Réponse attendue.",
        "255": "C'est la lecture sans signe.",
        "-128": "C'est 10000000 en complément à deux."
      }
    },
